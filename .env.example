# ─── VIKUP environment ─────────────────────────────────────────────────────
# Copy to `.env` and fill in real values. NEVER commit the real .env.

NODE_ENV=production
APP_URL=https://vikup.ghostpepe.fun
TZ=Europe/Moscow

# Optional public web discovery. Leave empty to run only internal history.
# SearXNG must have JSON output enabled.
SEARXNG_URL=
SEARXNG_TIMEOUT_MS=12000
SEARXNG_MAX_RESULTS=10

# PostgreSQL (managed / external). Use sslmode=require for managed providers.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# Session signing secret. Generate with: openssl rand -base64 48
AUTH_SECRET=

# ─── Telegram ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
# Shared secret sent by Telegram in the X-Telegram-Bot-Api-Secret-Token header.
# Generate with: openssl rand -hex 24
TELEGRAM_WEBHOOK_SECRET=

# ─── S3-compatible object storage ──────────────────────────────────────────
S3_ENDPOINT=https://s3.example.com
S3_REGION=ru-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true
# Optional: only if the bucket is public and you prefer direct URLs.
S3_PUBLIC_BASE_URL=

# ─── OCR / ANPR ────────────────────────────────────────────────────────────
# Internal URL of the OCR service (set automatically by docker-compose).
OCR_URL=http://ocr:8000
# Minimum OCR confidence (0..1) required to create a vehicle card.
OCR_CONFIDENCE_MIN=0.4
# ONNX models (downloaded and baked into the OCR image at build time).
OCR_MODEL=cct-s-v2-global-model
PLATE_DETECTOR_MODEL=yolo-v9-t-384-license-plate-end2end

# ─── Initial ADMIN (used only by `create-admin` on first startup) ──────────
# After the admin exists, the password is stored hashed and is NOT overwritten
# on subsequent deploys. Change/remove these once the admin is created.
ADMIN_NAME=Administrator
ADMIN_LOGIN=admin
ADMIN_PASSWORD=
